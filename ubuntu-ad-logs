variables:
  hostname: ${substring(to_lower(split(env.requestedBy, '.')[0] + '-' + env.shortDeploymentId), 0, 14)}
  user: ${split(env.requestedBy, '@')[0]}
  operations-for-logs: logs.arn.rainpole.io
  domain: arn.rainpole.io
  svc-account: svc-vsphere-ad
  ad-group: gg-nemea-employees
  nameserver01: 172.16.10.4
  nameserver02: 172.16.10.5
inputs:
  namespace-name:
    type: string
    title: Namespace
    description: |
      <h4>Namespace</h4> <p>Provide existing namespace name which is used as deployment target</p>
    $data: /data/namespaces?projectId={{project}}
  vm-class:
    type: string
    title: Virtual Machine Size
    description: |
      <h4>Select a Virtual Machine Size</h4>
      <p>
      <table class="table table-vertical table-compact">
        <tr>
          <th class="left">Size Name</th>
          <th class="left">Value</th>
        </tr>
        <tr>
          <td class="left"><small>Extra Small<br>(2 vCPUs - 2 GiB MEM)</small></td>
          <td class="left"><span class="label label-info">best-effort-xsmall</label></td>
        </tr>
        <tr>
          <td class="left"><small>Small<br>(2 vCPUs - 4 GiB MEM)</small></td>
          <td class="left"><span class="label label-info">best-effort-small</label></td>
        </tr>
        <tr>
          <td class="left"><small>Medium<br>(2 vCPUs - 4 GiB MEM)</small></td>
          <td class="left"><span class="label label-info">best-effort-medium</label></td>
        </tr>
        <tr>
          <td class="left"><small>Large<br>(2 vCPUs - 2 GiB MEM)</small></td>
          <td class="left"><span class="label label-info">best-effort-large</label></td>
        </tr>
      </table>
      </p>
    $data: /data/virtualmachineclasses?namespace={{namespace-name}}
    default: best-effort-xsmall
  vm-image:
    type: string
    title: Virtual Machine Image
    description: Select a Virtual Machine Image
    oneOf:
      - title: Ubuntu-20.25-plucky-server
        const: vmi-f0c18e325844fc0eb
      - title: Ubuntu-24.04-noble-server
        const: vmi-81775fc9d7e0c99bd
    default: vmi-81775fc9d7e0c99bd
  expose-ssh:
    type: boolean
    title: Assign public ip
resources:
  namespace:
    type: CCI.Supervisor.Namespace
    properties:
      name: ${input.namespace-name}
      existing: true
  linux_vm:
    type: CCI.Supervisor.Resource
    dependsOn:
      - secret
      - loadbalancer
    properties:
      context: ${resource.namespace.id}
      wait:
        conditions:
          - type: VirtualMachineCreated
            status: 'True'
      manifest:
        apiVersion: vmoperator.vmware.com/v1alpha3
        kind: VirtualMachine
        metadata:
          name: vm-${variable.hostname}
          labels:
            vm-lb-selector: vm-${variable.hostname}
            vm-selector: vm-${variable.hostname}
        spec:
          className: ${input.vm-class}
          imageName: ${input.vm-image}
          powerState: PoweredOn
          storageClass: vsan-default-storage-policy
          network:
            hostName: ${variable.hostname}
            domainName: ${variable.domain}
            nameservers:
              - ${variable.nameserver01}
              - ${variable.nameserver02}
            searchDomains:
              - ${variable.domain}
          bootstrap:
            cloudInit:
              rawCloudConfig:
                name: vm-${variable.hostname}-bootstrap-secret
                key: cloud-config
  loadbalancer:
    type: CCI.Supervisor.Resource
    properties:
      count: ${input.expose-ssh == true ? 1:0}
      context: ${resource.namespace.id}
      manifest:
        apiVersion: vmoperator.vmware.com/v1alpha3
        kind: VirtualMachineService
        metadata:
          name: vm-lb-${variable.hostname}
          namespace: ${input.namespace-name}
        spec:
          selector:
            vm-lb-selector: vm-${variable.hostname}
          type: LoadBalancer
          ports:
            - name: ssh
              port: 22
              protocol: TCP
              targetPort: 22
  secret:
    type: CCI.Supervisor.Resource
    properties:
      context: ${resource.namespace.id}
      manifest:
        apiVersion: v1
        kind: Secret
        metadata:
          name: vm-${variable.hostname}-bootstrap-secret
          labels:
            vm-selector: vm-${variable.hostname}
        stringData:
          cloud-config: |
            #cloud-config
            timezone: Europe/Stockholm
            fqdn: ${variable.hostname}.${variable.domain}
            ssh_pwauth: true
            users:
              - name: root
                passwd: $1$zDatx20t$Tp6YnKyoNBaHcbXuMtbfM1
                lock_passwd: false
                shell: /bin/bash
              - name: vmware
                gecos: vmware
                lock_passwd: false
                groups: sudo, users, admin
                shell: /bin/bash
                sudo: ALL=(ALL) NOPASSWD:ALL
                passwd: $1$zDatx20t$Tp6YnKyoNBaHcbXuMtbfM1
            package_upgrade: true
            package_update: true
            package_reboot_if_required: true
            packages:
              - sssd-ad
              - sssd-tools
              - realmd
              - adcli
            runcmd:
              - AD_DOMAIN=${variable.domain}
              - AD_GROUP=${variable.ad-group}
              - AD_SERVICEACCOUNT=${variable.svc-account}
              - sudo realm -v discover $AD_DOMAIN
              - echo "${secret.ad-join-password}" | sudo realm join -U $AD_SERVICEACCOUNT $AD_DOMAIN
              - sudo realm deny --all
              - sudo realm permit -g $AD_GROUP
              - echo "%$AD_GROUP@$AD_DOMAIN ALL=(ALL:ALL) ALL" >> /etc/sudoers
              - sudo pam-auth-update --enable mkhomedir
              - wget https://${variable.operations-for-logs}/api/v1/agent/packages/types/deb --no-check-certificate -O /tmp/liagent-current.deb --quiet
              - SERVERHOST=${variable.operations-for-logs} SERVERPROTO=cfapi SERVERPORT=9000 LIAGENT_AUTOUPDATE=yes LIAGENT_SSL=no dpkg -i /tmp/liagent-current.deb > /dev/null 2>&1
            power_state:
              delay: now
              mode: reboot
              message: Rebooting the OS
              condition: if [ -e /var/run/reboot-required ]; then exit 0; else exit 1; fi
